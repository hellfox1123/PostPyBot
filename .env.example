# Telegram Bot Token (отримати у @BotFather)
BOT_TOKEN=your_bot_token_here

# Telegram API credentials (отримати на https://my.telegram.org)
API_ID=12345678
API_HASH=your_api_hash_here

# Твій Telegram User ID (отримати у @userinfobot)
ADMIN_ID=123456789

# Username каналу-джерела (без @) або ID
SOURCE_CHANNEL=username_or_id

# ID цільового каналу (наприклад: -1001234567890)
TARGET_CHANNEL_ID=-1009876543210

# Шлях до бази даних (для Railway Volume)
DATABASE_PATH=/app/data/xposter.db

# Шлях до сесії Telethon
SESSION_PATH=/app/data/telegram_session

# Дефолтні налаштування
DEFAULT_INTERVAL_MINUTES=60
DEFAULT_MODE=randomsmart
DEFAULT_SMART_N=100